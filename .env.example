# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:replace-me

# Hermes API Server. Enable it in Hermes with API_SERVER_ENABLED=true.
HERMES_API_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev

# Comma-separated Telegram user IDs. Use * only for local testing.
TELEGRAM_ALLOWED_USERS=123456789

# Optional behavior
HERMES_CONVERSATION_PREFIX=telegram
HERMES_REQUEST_TIMEOUT_MS=180000
HERMES_USE_RUNS=false
